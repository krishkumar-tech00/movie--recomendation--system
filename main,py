import tkinter as tk

movies = {
    "Action": ["John Wick", "Mad Max", "The Dark Knight"],
    "Comedy": ["3 Idiots", "Hera Pheri", "Dhamaal"],
    "Sci-Fi": ["Interstellar", "Inception", "The Matrix"]
}

def recommend():
    genre = genre_var.get()

    if genre in movies:
        result_label.config(
            text="Recommended Movies:\n" + "\n".join(movies[genre])
        )
    else:
        result_label.config(text="Please select a genre.")

root = tk.Tk()
root.title("Movie Recommendation System")
root.geometry("400x300")

title_label = tk.Label(
    root,
    text="Movie Recommendation System",
    font=("Arial", 14, "bold")
)
title_label.pack(pady=10)

genre_var = tk.StringVar()

genre_menu = tk.OptionMenu(
    root,
    genre_var,
    "Action",
    "Comedy",
    "Sci-Fi"
)
genre_menu.pack(pady=10)

recommend_button = tk.Button(
    root,
    text="Recommend Movies",
    command=recommend
)
recommend_button.pack(pady=10)

result_label = tk.Label(root, text="")
result_label.pack(pady=10)

root.mainloop()